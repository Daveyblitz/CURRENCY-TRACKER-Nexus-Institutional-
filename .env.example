# ── Backend (server/) ─────────────────────────────────────────
# Port for local dev (Render injects its own PORT in production)
PORT=5000

# PostgreSQL connection string (Neon, Render Postgres, or local).
# Example (Neon): postgresql://user:pass@ep-xxx.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Bitnob API Settings (Optional - app runs in Simulator Mode if empty)
BITNOB_API_KEY=
BITNOB_ENV=sandbox

# ── Frontend (client/) ────────────────────────────────────────
# Leave EMPTY for local dev (Vite proxies /api to localhost:5000).
# In production (Vercel), set to the deployed backend origin, e.g.
# VITE_API_BASE=https://currency-tracker-api.onrender.com
VITE_API_BASE=
